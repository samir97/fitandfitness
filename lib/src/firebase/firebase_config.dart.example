import 'dart:io';

import 'package:firebase_core/firebase_core.dart';
import 'package:firebase_ui_auth/firebase_ui_auth.dart';
import 'package:firebase_ui_oauth_apple/firebase_ui_oauth_apple.dart';
import 'package:firebase_ui_oauth_google/firebase_ui_oauth_google.dart';
import 'package:fitandfitness/firebase_options.dart';

Future<void> initializeFirebase() async {
  await Firebase.initializeApp(
    options: DefaultFirebaseOptions.currentPlatform,
  );

  AuthProviderConfigurator.configureFirebaseUIAuth();
}

class AuthProviderConfigurator {
  static final Map<String, AuthProvider?> _providerMap = {
    AuthProviderIds.email: EmailAuthProvider(),
    AuthProviderIds.google:
        GoogleProvider(clientId: AuthProviderIds.googleClientId),
    if (Platform.isIOS) AuthProviderIds.apple: AppleProvider(),
  };

  static void configureFirebaseUIAuth() {
    FirebaseUIAuth.configureProviders(
      _providerMap.values.whereType<AuthProvider>().toList(),
    );
  }

  static List<AuthProvider> getAuthProviders(List<String> providerIds) {
    return providerIds
        .map((id) => _providerMap[id])
        .whereType<AuthProvider>()
        .toList();
  }
}

class AuthProviderIds {
  static const String email = 'password';
  static const String google = 'google.com';
  static const String facebook = 'facebook.com';
  static const String apple = 'apple.com';

  static const String googleClientId = 'YOUR_GOOGLE_CLIENT_ID';
}
